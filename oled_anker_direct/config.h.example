#pragma once

// ════════════════════════════════════════════════════
//  Copy this file to config.h and fill in your values.
//  cp config.h.example config.h
// ════════════════════════════════════════════════════

// Language: de  or  en  (no quotes)
#define LANGUAGE de

// WiFi
#define WIFI_SSID      "Your_WiFi_Name"
#define WIFI_PASSWORD  "Your_WiFi_Password"

// Anker account (app login credentials)
#define ANKER_EMAIL    "your@email.com"
#define ANKER_PASSWORD "your_anker_password"
#define ANKER_COUNTRY  "DE"

// Timezone offset in milliseconds (used in the login request body)
// GMT+1  = 3600000  (Germany winter / CET)
// GMT+2  = 7200000  (Germany summer / CEST)
#define ANKER_TZ_OFFSET_MS  3600000

// Data refresh interval in seconds
#define REFRESH_SEC  30

// OLED I2C pins (ESP32 defaults: SDA=21, SCL=22)
#define OLED_SDA  21
#define OLED_SCL  22
